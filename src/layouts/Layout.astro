---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
    title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <title>{title}</title>
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/png" href="/favicon.png" />
        <meta name="description" content="Trust Alliance - Soluciones Digitales Jurídicas" />

        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://trustalliance.ar/" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content="Trust Alliance - Soluciones Digitales Jurídicas" />
        <meta property="og:image" content="https://trustalliance.ar/trust-logo.png" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content="Trust Alliance - Soluciones Digitales Jurídicas" />
        <meta name="twitter:image" content="https://trustalliance.ar/trust-logo.png" />
        <ClientRouter /> 
    </head>
	<body>
		<slot />
        
        <script>
            import Lenis from '@studio-freight/lenis'

            // Envolvemos todo en astro:page-load para que Lenis se vuelva a cargar 
            // cada vez que la página hace la transición animada
            document.addEventListener('astro:page-load', () => {
                
                // 1. Configuración de Lenis
                const lenis = new Lenis({
                    duration: 1.2,
                    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
                    orientation: 'vertical',
                    gestureOrientation: 'vertical',
                    smoothWheel: true,
                })

                function raf(time: number) {
                    lenis.raf(time)
                    requestAnimationFrame(raf)
                }

                requestAnimationFrame(raf)

                // 2. Interceptar clicks en links para scroll ultra suave
                const links = document.querySelectorAll('a[href*="#"]');

                links.forEach(anchor => {
                    anchor.addEventListener('click', (e) => {
                        const element = e.currentTarget as HTMLAnchorElement;
                        const href = element.getAttribute('href');

                        if (!href || href === '#') return;

                        const [path, hash] = href.split('#');
                        
                        const currentPath = window.location.pathname;
                        const isHome = currentPath === '/' || currentPath === '/index.html';
                        const linkPointsToHome = path === '' || path === '/';

                        if (isHome && linkPointsToHome && hash) {
                            e.preventDefault(); 

                            const targetElement = document.querySelector('#' + hash);
                            if (targetElement) {
                                lenis.scrollTo(targetElement as HTMLElement, {
                                    offset: -100, 
                                    duration: 1.5,
                                    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
                                });
                            }
                        }
                    });
                });

                // 3. Manejar la carga inicial si venimos de OTRA página
                if (window.location.hash) {
                    const targetElement = document.querySelector(window.location.hash);
                    
                    if (targetElement) {
                        window.scrollTo(0, 0); 
                        
                        setTimeout(() => {
                            lenis.scrollTo(targetElement as HTMLElement, {
                                offset: -100,
                                duration: 1.5,
                                easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
                            });
                        }, 150);
                    }
                }
            });
        </script>
	</body>
</html>