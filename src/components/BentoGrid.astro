---
/* BentoGrid.astro - Versión Legal Tech (Mobile & Notebook Optimized) */
---

<section id="soluciones" class="bento-wrapper">
    <div class="container">
        <div class="header">
            <span class="pill">Ecosistema Inteligente</span>
            <h2>Tecnología de punta <br><span class="text-gradient">aplicada al derecho</span></h2>
            <p>Para que cada cliente tenga control, información y resultados en tiempo real.</p>
        </div>

        <div id="cards" class="bento-grid">
            
            <div class="card col-span-2 row-span-2">
                <div class="card-content main-content">
                    <div class="badge">Nuestra Esencia</div>
                    <h3>Donde la tecnología <br> <span class="highlight">se encuentra con el derecho.</span></h3>
                    <p>Desarrollamos soluciones innovadoras que conectan clientes, abogados y tecnología avanzada. Transformamos el modelo tradicional en un ecosistema legal inteligente.</p>
                    <a href="#contacto" class="btn-text">Explorar Soluciones &rarr;</a>
                </div>
            </div>

            <div class="card col-span-1 row-span-1">
                <div class="card-content legal-tech-content">
                    <div class="doc-container">
                        <div class="doc-paper">
                            <div class="line short"></div>
                            <div class="line long"></div>
                            <div class="line long"></div>
                            <div class="line short"></div>
                            <div class="scan-beam"></div>
                            <div class="status-badge">
                                <span class="checkmark">✓</span>
                            </div>
                        </div>
                    </div>
                    <h4>Automatización</h4>
                    <p class="small">Procesos optimizados con tecnología.</p>
                </div>
            </div>

            <div class="card col-span-1 row-span-1">
                <div class="card-content center-content">
                    <div class="radar-container">
                        <div class="radar-sweep"></div>
                        <div class="radar-dot"></div>
                    </div>
                    <h4>Trazabilidad</h4>
                    <p class="small">Cada etapa registrada en tiempo real.</p>
                </div>
            </div>

            <div class="card col-span-1 row-span-1">
                <div class="card-content">
                    <div class="chart-container">
                        <div class="bar bar-1"></div>
                        <div class="bar bar-2"></div>
                        <div class="bar bar-3"></div>
                        <div class="bar bar-4"></div>
                    </div>
                    <h4>Transparencia</h4>
                    <p class="small">Estado del caso en todo momento.</p>
                </div>
            </div>

            <div class="card col-span-1 row-span-1">
                <div class="card-content ux-content">
                    <div class="ui-circle"></div>
                    <div class="ui-card-glass"></div>
                    <h4>Gestión Inteligente</h4>
                    <p class="small">Acelera la resolución de conflictos.</p>
                </div>
            </div>

        </div>
    </div>
</section>

<script>
    document.addEventListener('astro:page-load', () => {
        const cardsContainer = document.getElementById("cards");
        
        // Detectamos si es una pantalla grande (Desktop/Notebook)
        const isDesktop = window.matchMedia("(min-width: 768px)").matches;

        if (cardsContainer && isDesktop) {
            cardsContainer.onmousemove = (e) => {
                for (const card of document.getElementsByClassName("card")) {
                    const rect = card.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;
                    (card as HTMLElement).style.setProperty("--mouse-x", `${x}px`);
                    (card as HTMLElement).style.setProperty("--mouse-y", `${y}px`);
                }
            };
        }
    });
</script>

<style>
    /* --- ESTRUCTURA GENERAL --- */
    .bento-wrapper {
        padding: 6rem 0; /* Padding un poco menor en mobile */
        background-color: var(--bg-main);
        overflow: hidden; /* Evita scroll horizontal accidental */
    }

    .container {
        padding: 0 1.5rem; /* Padding lateral seguro para mobile */
        max-width: 1200px;
        margin: 0 auto;
    }

    .header { text-align: center; margin-bottom: 3rem; max-width: 700px; margin-left: auto; margin-right: auto; }
    
    .pill {
        color: var(--accent); font-size: 0.8rem; font-weight: 600;
        letter-spacing: 2px; text-transform: uppercase; margin-bottom: 0.8rem; display: block;
    }

    .header h2 { 
        font-size: 2.5rem; /* Tamaño base mobile */
        margin-bottom: 1rem; line-height: 1.1; color: var(--text-primary); 
    }
    .header p { color: var(--text-secondary); font-size: 1rem; padding: 0 1rem; }
    
    .text-gradient {
        background: linear-gradient(to right, #fff, #94a3b8);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }

    /* --- GRID SETUP (MOBILE FIRST) --- */
    .bento-grid {
        display: grid;
        /* Por defecto 1 columna (Mobile) */
        grid-template-columns: 1fr;
        gap: 1rem;
        width: 100%;
    }

    /* --- SPOTLIGHT EFFECT & CARD BASE --- */
    .card {
        background-color: rgba(15, 23, 42, 0.4);
        border-radius: 16px;
        position: relative;
        overflow: hidden; 
        display: flex;
        flex-direction: column;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: transform 0.2s;
        min-height: 250px; /* Altura mínima segura */
    }

    /* Efectos visuales de la tarjeta (Spotlight) */
    .card::before {
        content: ""; position: absolute; inset: 0; border-radius: 16px; padding: 1px;
        background: radial-gradient(800px circle at var(--mouse-x) var(--mouse-y), rgba(255, 255, 255, 0.4), transparent 40%);
        -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor; mask-composite: exclude; opacity: 0; transition: opacity 0.5s; pointer-events: none; z-index: 3;
    }

    .card::after {
        content: ""; position: absolute; inset: 0;
        background: radial-gradient(600px circle at var(--mouse-x) var(--mouse-y), rgba(56, 189, 248, 0.08), transparent 40%);
        opacity: 0; transition: opacity 0.5s; pointer-events: none; z-index: 1;
    }

    /* En mobile (touch) el hover no siempre funciona igual, pero lo dejamos activo */
    .bento-grid:hover .card::before, .bento-grid:hover .card::after { opacity: 1; }

    /* --- CONTENIDO --- */
    .card-content {
        padding: 1.5rem; /* Padding interno mobile */
        height: 100%; width: 100%; position: relative; z-index: 10;
        display: flex; flex-direction: column; box-sizing: border-box;
    }
    
    h4 { color: var(--text-primary); font-size: 1.2rem; margin-bottom: 0.2rem; }
    .small { font-size: 0.85rem; color: var(--text-secondary); }

    /* --- ESTILOS ESPECÍFICOS DE TARJETAS --- */
    
    /* CARD 1: MAIN */
    .main-content { justify-content: space-between; }
    .badge {
        display: inline-block; padding: 6px 14px; border-radius: 20px;
        background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
        font-size: 0.75rem; color: var(--accent); font-weight: 600; width: fit-content; margin-bottom: 1rem;
    }
    .main-content h3 { font-size: 2rem; line-height: 1.1; margin-bottom: 1rem; color: var(--text-primary); }
    .highlight { color: var(--accent); }
    .main-content p { color: var(--text-secondary); margin-bottom: 1.5rem; font-size: 0.95rem; }
    .btn-text { color: var(--text-primary); margin-top: auto; font-size: 1rem; font-weight: 600; display: inline-block; }
    
    /* CARD 2: DOCUMENT */
    .legal-tech-content { justify-content: flex-end; background: radial-gradient(circle at top left, rgba(56,189,248,0.05), transparent); }
    .doc-container {
        position: absolute; top: 15px; left: 50%; transform: translateX(-50%);
        width: 100%; height: 60%; display: flex; justify-content: center; align-items: center;
    }
    .doc-paper {
        width: 70px; height: 90px;
        background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px; padding: 10px; display: flex; flex-direction: column; gap: 6px;
        position: relative; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }
    .line { height: 3px; background: rgba(255,255,255,0.1); border-radius: 2px; }
    .line.short { width: 60%; } .line.long { width: 100%; }
    .scan-beam {
        position: absolute; top: -20%; left: 0; width: 100%; height: 20px;
        background: linear-gradient(to bottom, transparent, var(--accent), transparent); opacity: 0.5;
        animation: scan 3s infinite ease-in-out;
    }
    .status-badge {
        position: absolute; bottom: 8px; right: 8px; width: 20px; height: 20px;
        background: var(--accent); border-radius: 50%; display: flex; align-items: center; justify-content: center;
        box-shadow: 0 0 10px var(--accent); animation: pop-in 3s infinite;
    }
    .checkmark { color: var(--bg-main); font-size: 12px; font-weight: bold; }
    
    /* Animaciones */
    @keyframes scan { 0% { top: -20%; } 100% { top: 120%; } }
    @keyframes pop-in { 0%, 80% { transform: scale(0); opacity: 0; } 90%, 100% { transform: scale(1); opacity: 1; } }

    /* CARD 3: RADAR */
    .center-content { align-items: center; justify-content: center; text-align: center; }
    .radar-container {
        width: 90px; height: 90px; border: 1px solid rgba(255,255,255,0.1); border-radius: 50%;
        position: relative; margin-bottom: 1rem; background: radial-gradient(circle, rgba(56,189,248,0.05), transparent); overflow: hidden;
    }
    .radar-sweep {
        position: absolute; inset: 0; background: conic-gradient(from 0deg, transparent 0deg, rgba(56,189,248,0.5) 360deg);
        animation: radar-spin 2s linear infinite; border-radius: 50%;
    }
    .radar-dot {
        position: absolute; top: 30%; left: 60%; width: 6px; height: 6px;
        background: #ef4444; border-radius: 50%; box-shadow: 0 0 5px #ef4444; animation: blink 2s infinite;
    }
    @keyframes radar-spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    @keyframes blink { 50% { opacity: 0; } }

    /* CARD 4: ANALYTICS */
    .chart-container { display: flex; align-items: flex-end; gap: 8px; height: 70px; margin-bottom: 1rem; margin-top: auto; }
    .bar { width: 12px; background: rgba(255,255,255,0.1); border-radius: 2px; transition: height 0.5s; }
    /* Animaciones barras (reducidas para ahorrar código repetitivo) */
    .bar-1 { height: 40%; animation: bar-rise 2s infinite alternate; }
    .bar-2 { height: 70%; animation: bar-rise 2.5s infinite alternate-reverse; }
    .bar-3 { height: 50%; animation: bar-rise 1.8s infinite alternate; }
    .bar-4 { height: 85%; animation: bar-rise 2.2s infinite alternate-reverse; }
    @keyframes bar-rise { from { height: 20%; background: rgba(255,255,255,0.1); } to { height: 95%; background: var(--accent); box-shadow: 0 0 10px var(--accent); } }

    /* CARD 5: UX */
    .ux-content { background: radial-gradient(circle at top right, rgba(139,92,246,0.08), transparent); justify-content: flex-end; }
    .ui-circle {
        position: absolute; top: 20px; right: 20px; width: 40px; height: 40px; border-radius: 50%;
        border: 2px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.02);
    }
    .ui-card-glass {
        position: absolute; top: 40px; left: 20px; width: 100px; height: 60px;
        background: rgba(255,255,255,0.05); backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.15); border-radius: 10px;
        transform: rotate(-10deg); box-shadow: 0 10px 30px rgba(0,0,0,0.3); transition: transform 0.5s;
    }

    /* --- RESPONSIVE BREAKPOINTS --- */
    
    /* TABLET & NOTEBOOK (min-width: 768px) */
    @media (min-width: 768px) {
        .bento-wrapper { padding: 8rem 0; }
        .header h2 { font-size: 3rem; }
        
        .bento-grid {
            /* 2 Columnas para tablets */
            grid-template-columns: repeat(2, 1fr); 
            grid-auto-rows: 260px;
        }

        /* Configuración específica para 2 columnas */
        .col-span-2 { grid-column: span 2; }
        /* Las demás ocupan 1 por defecto */
        
        .card-content { padding: 2rem; }
        .main-content h3 { font-size: 2.2rem; }
    }

    /* DESKTOP (min-width: 1024px) */
    @media (min-width: 1024px) {
        .bento-grid {
            /* 3 Columnas originales */
            grid-template-columns: repeat(3, 1fr);
        }
        
        /* Restaurar layout original de 3 columnas */
        .col-span-2 { grid-column: span 2; }
        .row-span-2 { grid-row: span 2; }
        
        .main-content h3 { font-size: 2.5rem; }
    }
</style>