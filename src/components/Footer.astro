---
const currentYear = new Date().getFullYear();
---

<footer class="footer-section">
    <div class="footer-glow"></div>

    <div class="container">
        
        <div class="cta-wrapper">
            <h2 class="cta-title">El derecho está evolucionando.<br>Y nosotros también.</h2>
            <div class="cta-actions">
                <a href="/#contacto" class="btn-primary-large">
                    Transformá tu firma
                    <span class="icon">↗</span>
                </a>
                <p class="cta-subtitle">LegalTech que transforma procesos en experiencias inteligentes.</p>
            </div>
        </div>

        <div class="divider"></div>

        <div class="footer-grid">
            
            <div class="brand-col">
                <div class="logo">TRUST<span class="dot">.</span></div>
                <p>Soluciones digitales innovadoras y seguras para el sector jurídico.</p>
                <div class="socials">
                    <a href="https://instagram.com/trustalliance.ar" target="_blank" class="social-link">Instagram</a>
                    <a href="#" class="social-link">LinkedIn</a>
                    <a href="mailto:info@trustalliance.ar" class="social-link">Email</a>
                </div>
            </div>

            <div class="nav-group">
                <div class="nav-col">
                    <h4>Explorar</h4>
                    <ul>
                        <li><a href="/#soluciones">Soluciones</a></li>
                        <li><a href="/#metodo">Metodología</a></li>
                        <li><a href="/#proyectos">Casos de Éxito</a></li>
                    </ul>
                </div>

                <div class="nav-col">
                    <h4>Legales</h4>
                    <ul>
                        <li><a href="#">Privacidad</a></li>
                        <li><a href="#">Términos</a></li>
                    </ul>
                </div>
            </div>

        </div>

        <div class="big-text-wrapper">
            <span class="big-text">TRUST<br class="mobile-break"> ALLIANCE</span>
        </div>

        <div class="bottom-bar">
            <span>&copy; {currentYear} Trust Alliance.</span>
            <span class="made-by">Diseñado en Buenos Aires 🇦🇷</span>
        </div>
    </div>
</footer>

<style>
    /* --- MOBILE FIRST BASE STYLES --- */
    .footer-section {
        background-color: #020617; /* Slate 950 */
        color: var(--text-primary);
        padding-top: 5rem; /* Padding mobile */
        padding-bottom: 2rem;
        position: relative;
        overflow: hidden;
    }

    .container {
        padding: 0 1.5rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    /* Luz superior */
    .footer-glow {
        position: absolute; top: 0; left: 0; right: 0; height: 1px;
        background: radial-gradient(circle, rgba(56, 189, 248, 0.5) 0%, transparent 70%);
        box-shadow: 0 0 20px rgba(56, 189, 248, 0.2);
    }

    /* --- CTA --- */
    .cta-wrapper {
        display: flex; flex-direction: column; gap: 2.5rem; margin-bottom: 4rem;
    }

    .cta-title {
        font-size: 2.5rem; /* Tamaño mobile */
        line-height: 1.1;
        background: linear-gradient(to bottom, #fff, #94a3b8);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }

    .cta-actions {
        display: flex; flex-direction: column; align-items: flex-start; gap: 1rem; width: 100%;
    }

    .btn-primary-large {
        background: var(--text-primary); color: var(--bg-main);
        padding: 16px 0; /* Full width button en mobile */
        width: 100%; justify-content: center;
        border-radius: 50px; font-size: 1.1rem; font-weight: 700;
        display: flex; align-items: center; gap: 1rem;
        transition: transform 0.3s ease;
    }
    
    .cta-subtitle { font-size: 0.9rem; color: var(--text-secondary); }

    .divider {
        height: 1px; background: rgba(255,255,255,0.1); margin-bottom: 3rem;
    }

    /* --- GRID --- */
    .footer-grid {
        display: flex; flex-direction: column; gap: 3rem; margin-bottom: 4rem;
    }

    .brand-col p {
        margin: 1.5rem 0; font-size: 0.95rem; color: var(--text-secondary); max-width: 300px;
    }

    .logo { font-family: var(--font-heading); font-weight: 800; font-size: 1.5rem; }
    .dot { color: var(--accent); }

    .socials { display: flex; gap: 1.5rem; }
    .social-link {
        font-size: 0.9rem; font-weight: 600; color: var(--text-primary); position: relative;
    }

    /* Agrupamos columnas de navegación para mobile */
    .nav-group {
        display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;
    }

    .nav-col h4 { margin-bottom: 1.2rem; font-size: 1rem; color: var(--text-primary); }
    .nav-col ul { list-style: none; padding: 0; margin: 0; }
    .nav-col li { margin-bottom: 0.8rem; }
    .nav-col a { color: var(--text-secondary); transition: 0.3s; font-size: 0.9rem; }

    /* --- BIG TEXT (CORREGIDO) --- */
    .big-text-wrapper {
        display: flex; justify-content: center; margin-bottom: 2rem;
        opacity: 0.1; pointer-events: none; user-select: none;
    }

    .big-text {
        font-family: var(--font-heading);
        font-weight: 900;
        line-height: 0.85;
        text-align: center;
        background: linear-gradient(to bottom, rgba(255,255,255,0.8), transparent);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        
        /* MOBILE: 18vw hace que entre perfecto en dos líneas */
        font-size: 18vw; 
    }
    
    .mobile-break { display: block; } /* Activo en mobile */

    /* --- BOTTOM BAR --- */
    .bottom-bar {
        border-top: 1px solid rgba(255,255,255,0.05);
        padding-top: 2rem;
        display: flex; flex-direction: column; gap: 1rem;
        text-align: center; font-size: 0.8rem; color: var(--text-secondary);
    }

    /* --- DESKTOP OVERRIDES (min-width: 900px) --- */
    @media (min-width: 900px) {
        .footer-section { padding-top: 8rem; padding-bottom: 4rem; }

        /* CTA */
        .cta-wrapper {
            flex-direction: row; justify-content: space-between; align-items: center;
        }
        .cta-title { font-size: 3.5rem; }
        .cta-actions { width: auto; align-items: flex-end; }
        .btn-primary-large { width: auto; padding: 18px 36px; }
        .btn-primary-large:hover { transform: scale(1.05); background: var(--accent); }

        /* GRID */
        .footer-grid {
            display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 4rem;
        }
        .nav-group { display: contents; } /* Deshace el grid interno mobile */

        .nav-col a:hover { color: var(--accent); padding-left: 5px; }
        .social-link::after {
            content: ''; position: absolute; left: 0; bottom: -2px; width: 0; height: 1px;
            background: var(--accent); transition: width 0.3s;
        }
        .social-link:hover::after { width: 100%; }

        /* BIG TEXT FIXED */
        .big-text {
            /* DESKTOP: 11.5vw es el número mágico para que entre en una línea */
            font-size: 11.5vw;
        }
        .mobile-break { display: none; } /* Ocultamos el salto de línea */

        /* BOTTOM BAR */
        .bottom-bar {
            flex-direction: row; justify-content: space-between; text-align: left;
        }
    }
</style>