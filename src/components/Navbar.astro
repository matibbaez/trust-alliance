---
// Importamos la herramienta de imagen de Astro y el nuevo logo
import { Image } from 'astro:assets';
import logoTrust from '../assets/trust-logo.png';
---

<header id="navbar" class="nav-island">
    <div class="nav-container">
        
        <a href="/#hero" class="logo">
            <Image 
                src={logoTrust} 
                alt="Trust Alliance Logo" 
                height={50}
                format="webp"
                class="nav-logo-img"
            />
        </a>

        <nav class="desktop-menu">
            <a href="/#soluciones" class="nav-link">Soluciones</a>
            <a href="/#proyectos" class="nav-link">Proyectos</a>
            <a href="/#metodo" class="nav-link">Método</a>
        </nav>

        <div class="nav-actions">
            <a href="/#contacto" class="btn-nav desktop-only">Agendar</a>

            <button id="menu-toggle" class="hamburger" aria-label="Abrir menú">
                <span class="line top"></span>
                <span class="line bottom"></span>
            </button>
        </div>
    </div>
</header>

<div id="mobile-menu" class="mobile-overlay">
    <nav class="mobile-nav-links">
        <a href="/#soluciones" class="mobile-link">Soluciones</a>
        <a href="/#proyectos" class="mobile-link">Proyectos</a>
        <a href="/#metodo" class="mobile-link">Método</a>
        <div class="separator"></div>
        <a href="/#contacto" class="btn-mobile">Agendar Reunión</a>
    </nav>
</div>

<script>
    document.addEventListener('astro:page-load', () => {
        const nav = document.getElementById('navbar');
        const toggleBtn = document.getElementById('menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        const mobileLinks = document.querySelectorAll('.mobile-link, .btn-mobile');

        // 1. Scroll Animation (Expandir Isla)
        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                nav?.classList.add('expanded');
            } else {
                nav?.classList.remove('expanded');
            }
        });

        // 2. Toggle Menú Mobile + Accesibilidad (a11y)
        toggleBtn?.addEventListener('click', () => {
            // Actualizamos el estado para lectores de pantalla
            const isExpanded = toggleBtn.getAttribute('aria-expanded') === 'true';
            toggleBtn.setAttribute('aria-expanded', String(!isExpanded));
            
            toggleBtn.classList.toggle('active');
            mobileMenu?.classList.toggle('open');
            document.body.classList.toggle('no-scroll'); // Evitar scroll de fondo
        });

        // 3. Cerrar menú al tocar un link
        mobileLinks.forEach(link => {
            link.addEventListener('click', () => {
                toggleBtn?.setAttribute('aria-expanded', 'false');
                toggleBtn?.classList.remove('active');
                mobileMenu?.classList.remove('open');
                document.body.classList.remove('no-scroll');
            });
        });
    });
</script>

<style>
    /* --- 1. ESTILOS BASE (MOBILE FIRST) --- */
    .nav-island {
        position: fixed;
        top: 1rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1000;
        
        /* En mobile, ocupamos casi todo el ancho */
        width: 90%; 
        height: 70px;
        
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 100px;
        
        display: flex;
        align-items: center;
        justify-content: center;
        
        /* Animación suave */
        transition: all 2.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .nav-container {
        width: 100%;
        padding: 0 1.2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .logo {
        display: flex;
        align-items: center;
        padding: 5px 0;
    }

    .nav-logo-img {
        width: auto; /* Para que mantenga la proporción */
        transition: transform 0.3s ease;
    }

    .nav-island.expanded .nav-logo-img {
        transform: scale(0.9);
    }

    /* Ocultamos menú desktop en mobile */
    .desktop-menu, .desktop-only { display: none; }

    /* --- HAMBURGUESA ANIMADA --- */
    .hamburger {
        background: none; border: none; cursor: pointer;
        width: 40px; height: 40px;
        display: flex; flex-direction: column; justify-content: center; align-items: flex-end;
        gap: 6px; z-index: 1001; padding: 0;
    }

    .line {
        width: 24px; height: 2px;
        background-color: var(--text-primary);
        border-radius: 2px;
        transition: all 0.3s ease;
    }
    
    /* Animación a X */
    .hamburger.active .top { transform: rotate(45deg) translate(5px, 6px); }
    .hamburger.active .bottom { transform: rotate(-45deg) translate(5px, -6px); }

    /* --- OVERLAY MOBILE --- */
    .mobile-overlay {
        position: fixed; inset: 0;
        background: rgba(2, 6, 23, 0.95);
        backdrop-filter: blur(20px);
        z-index: 999;
        display: flex; justify-content: center; align-items: center;
        opacity: 0; pointer-events: none;
        transition: opacity 0.4s ease;
    }

    .mobile-overlay.open { opacity: 1; pointer-events: all; }

    .mobile-nav-links {
        display: flex; flex-direction: column; align-items: center; gap: 2rem;
        transform: translateY(20px); transition: transform 0.4s ease;
    }
    .mobile-overlay.open .mobile-nav-links { transform: translateY(0); }

    .mobile-link {
        font-size: 2rem; font-weight: 700; color: var(--text-primary);
    }
    .mobile-link:hover { color: var(--accent); }

    .separator { width: 40px; height: 2px; background: rgba(255,255,255,0.1); }

    .btn-mobile {
        font-size: 1.2rem; color: var(--accent); font-weight: 600;
    }

    /* --- 2. ESTILOS DESKTOP (MEDIA QUERIES) --- */
    @media (min-width: 900px) {
        .nav-island {
            top: 2rem;
            height: 80px; /* Un poco más alta en desktop para el logo grande */
            width: 720px;
        }

        /* Lógica de expansión SOLO en Desktop */
        .nav-island.expanded {
            width: 94%; max-width: 1400px; top: 1rem;
            background: rgba(2, 6, 23, 0.85);
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            height: 70px;
        }

        .nav-container { padding: 0 2rem; }

        /* Mostrar elementos Desktop */
        .desktop-menu { display: flex; gap: 2.5rem; }
        .desktop-only { display: inline-flex; }
        
        /* Ocultar elementos Mobile */
        .hamburger { display: none; }
        .mobile-overlay { display: none; }

        /* Links */
        .nav-link {
            font-size: 0.95rem; font-weight: 500; color: var(--text-secondary);
            transition: color 0.3s; position: relative;
        }
        .nav-link:hover { color: var(--text-primary); }
        .nav-link::after {
            content: ''; position: absolute; bottom: -6px; left: 50%; transform: translateX(-50%);
            width: 0; height: 2px; background: var(--accent); transition: width 0.3s;
        }
        .nav-link:hover::after { width: 100%; }

        /* Botón Agendar Desktop */
        .btn-nav {
            background: rgba(255, 255, 255, 0.08); padding: 10px 28px;
            border-radius: 50px; font-size: 0.9rem; font-weight: 600;
            transition: 0.3s; border: 1px solid rgba(255,255,255,0.05);
            color: var(--text-primary);
        }
        .btn-nav:hover {
            background: var(--text-primary); color: var(--bg-main);
            box-shadow: 0 0 20px rgba(255,255,255,0.2);
        }
    }

    /* Clase utilitaria para bloquear scroll cuando abre menú */
    :global(.no-scroll) { overflow: hidden; }
</style>